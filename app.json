{
  "expo": {
    "name": "RAS Store",
    "slug": "rahul-auto-spares",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060E06"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060E06"
      },
      "package": "com.rahulautospares.store",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "eas": {
        "projectId": "02693dd5-74df-488e-ba61-7a16ab7b8965"
      }
    },
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-notifications",
      "./plugins/withFullScreenOrderAlert.js",
      "expo-image-picker",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "rahul-auto-spares"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.rahulautospares.store"
    }
  }
}
